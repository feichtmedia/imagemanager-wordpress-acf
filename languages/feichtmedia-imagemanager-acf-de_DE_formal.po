msgid "FeichtMedia ImageManager"
msgstr "FeichtMedia ImageManager"

msgid "API Connection"
msgstr "API-Verbindung"

msgid "API Key"
msgstr "API-Schlüssel"

msgid "Project ID"
msgstr "Projekt-ID"

msgid "CDN Domain"
msgstr "CDN-Domain"

msgid "Read-only API key for the ImageManager API (Bearer token)."
msgstr "Read-only-API-Schlüssel für die ImageManager API (Bearer-Token)."

msgid "Your ImageManager usergroup / project ID (e.g. wordpress)."
msgstr "Ihre ImageManager-Benutzergruppe / Projekt-ID (z. B. wordpress)."

msgid "CDN domain without protocol (e.g. cdn.example.com). The protocol will be stripped automatically."
msgstr "CDN-Domain ohne Protokoll (z. B. cdn.example.com). Das Protokoll wird automatisch entfernt."

msgid "Please enter a valid CDN domain without a protocol, path, or port (e.g. cdn.example.com). Your change was not saved."
msgstr "Bitte geben Sie eine gültige CDN-Domain ohne Protokoll, Pfad oder Port ein (z. B. cdn.example.com). Ihre Änderung wurde nicht gespeichert."

msgid "FeichtMedia ImageManager: Please complete the plugin settings under <a href=\"%s\">Settings &#8594; FeichtMedia ImageManager</a>."
msgstr "FeichtMedia ImageManager: Bitte vervollständigen Sie die Plugin-Einstellungen unter <a href=\"%s\">Einstellungen &#8594; FeichtMedia ImageManager</a>."

msgid "ACF Field"
msgstr "ACF-Feld"

msgid "Metadata Cache"
msgstr "Metadaten-Cache"

msgid "Enable metadata cache"
msgstr "Metadaten-Cache aktivieren"

msgid "Caches ImageManager API metadata responses in WordPress transients. Applies only to ACF field value reads (e.g. get_field(), GraphQL) — the image browser in the editor is not affected. Disable for debugging or when image metadata changes frequently."
msgstr "Speichert Metadaten-Antworten der ImageManager API in WordPress-Transients. Gilt nur für ACF-Feldwert-Abfragen (z. B. get_field(), GraphQL) – nicht für die Bildauswahl im Editor. Deaktivieren zum Debuggen oder wenn sich Bildmetadaten häufig ändern."

msgid "Cache TTL"
msgstr "Cache-TTL"

msgid "How long API responses are cached, in seconds. Default: 3600 (1 hour). Set to 0 for no expiry."
msgstr "Wie lange API-Antworten in Sekunden gecacht werden. Standard: 3600 (1 Stunde). 0 = kein Ablauf."

msgid "Image"
msgstr "Bild"

msgid "Return Format"
msgstr "Rückgabeformat"

msgid "Relative URL"
msgstr "Relative URL"

msgid "Absolute URL"
msgstr "Absolute URL"

msgid "Metadata Object"
msgstr "Metadaten-Objekt"

msgid "Allow Null"
msgstr "Leer erlauben"

msgid "&#9888; Configuration incomplete. Please complete all settings under <a href=\"%s\">Settings &#8594; FeichtMedia ImageManager</a>."
msgstr "&#9888; Konfiguration unvollständig. Bitte vervollständigen Sie alle Einstellungen unter <a href=\"%s\">Einstellungen &#8594; FeichtMedia ImageManager</a>."

msgid "Add image"
msgstr "Bild hinzufügen"

msgid "Change image"
msgstr "Bild ändern"

msgid "Remove"
msgstr "Entfernen"

msgid "Image not found."
msgstr "Bild nicht gefunden."

msgid "Search…"
msgstr "Suchen…"

msgid "No images found."
msgstr "Keine Bilder gefunden."

msgid "No categories found."
msgstr "Keine Kategorien gefunden."

msgid "Could not load images. Please try again."
msgstr "Bilder konnten nicht geladen werden. Bitte versuchen Sie es erneut."

msgid "Could not load categories. Please try again."
msgstr "Kategorien konnten nicht geladen werden. Bitte versuchen Sie es erneut."

msgid "Showing %1$d of %2$d"
msgstr "%1$d von %2$d angezeigt"

msgid "Select image"
msgstr "Bild auswählen"

msgid "Select"
msgstr "Auswählen"

msgid "Close"
msgstr "Schließen"

msgid "Loading…"
msgstr "Wird geladen…"

msgid "Load more"
msgstr "Mehr laden"

msgid "All images"
msgstr "Alle Bilder"

msgid "The ImageManager API key is not configured. Please check your settings."
msgstr "Der ImageManager-API-Schlüssel ist nicht konfiguriert. Bitte überprüfen Sie Ihre Einstellungen."

msgid "View in ImageManager"
msgstr "Im ImageManager ansehen"

msgid "Try again"
msgstr "Erneut versuchen"

msgid "Upload"
msgstr "Hochladen"

msgid "An image from the FeichtMedia ImageManager"
msgstr "Ein Bild aus dem FeichtMedia ImageManager"

msgid "FeichtMedia ImageManager for Advanced Custom Fields requires Advanced Custom Fields (ACF) to be installed and active."
msgstr "FeichtMedia ImageManager for Advanced Custom Fields erfordert, dass Advanced Custom Fields (ACF) installiert und aktiviert ist."

